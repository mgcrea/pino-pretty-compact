{
  "name": "@mgcrea/pino-pretty-compact",
  "version": "1.6.0",
  "description": "Compact request logger plugin for fastify written in TypeScript",
  "author": "Olivier Louvignes <olivier@mgcrea.io>",
  "repository": "github:mgcrea/pino-pretty-compact",
  "license": "MIT",
  "access": "public",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.cjs",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "bin": {
    "pino-pretty-compact": "./dist/bin/cli.js"
  },
  "scripts": {
    "start": "npm run spec -- --watch",
    "build": "tsup --entry src/index.ts --format cjs,esm --no-splitting --sourcemap --dts --clean --entry src/bin/cli.ts",
    "lint": "eslint src/ test/ --ignore-pattern test/fixtures/target.mjs",
    "prettycheck": "prettier --check src/ test/",
    "prettify": "prettier --write src/ test/",
    "check": "tsc --noEmit",
    "spec": "vitest --run",
    "test": "npm run lint && npm run prettycheck && npm run check && npm run spec",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "pino",
    "pretty",
    "compact",
    "fastify",
    "logger"
  ],
  "devDependencies": {
    "@mgcrea/eslint-config-node": "^0.14.1",
    "@mgcrea/fastify-request-logger": "^1.9.1",
    "@tsconfig/esm": "^1.0.5",
    "@tsconfig/node-lts": "^24.0.0",
    "@tsconfig/strictest": "^2.0.8",
    "@types/http-errors": "^2.0.5",
    "@types/node": "^22.9.0",
    "eslint": "^9.14.0",
    "fastify": "^5.7.4",
    "http-errors": "^2.0.1",
    "pino": "^10.3.1",
    "pino-std-serializers": "^7.1.0",
    "prettier": "^3.8.1",
    "prettier-plugin-organize-imports": "^4.3.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "kolorist": "^1.8.0",
    "pino-pretty": "^13.1.3"
  },
  "packageManager": "pnpm@10.30.3"
}
